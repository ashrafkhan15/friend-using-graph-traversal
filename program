#include <stdio.h>

int main() {
    int rows, cols;
    int matrix[10][10], rotated[10][10];
    int i, j;

    printf("=====================================\n");
    printf("      MATRIX ROTATION PROJECT\n");
    printf("=====================================\n");

    printf("Enter number of rows: ");
    scanf("%d", &rows);

    printf("Enter number of columns: ");
    scanf("%d", &cols);

    printf("Enter matrix elements:\n");

    for(i = 0; i < rows; i++) {
        for(j = 0; j < cols; j++) {
            scanf("%d", &matrix[i][j]);
        }
    }

    printf("\nOriginal Matrix:\n");
    for(i = 0; i < rows; i++) {
        for(j = 0; j < cols; j++) {
            printf("%4d", matrix[i][j]);
        }
        printf("\n");
    }

    /* 90 Degree Clockwise Rotation Logic */
    for(i = 0; i < rows; i++) {
        for(j = 0; j < cols; j++) {
            rotated[j][rows - 1 - i] = matrix[i][j];
        }
    }

    printf("\nMatrix After 90 Degree Clockwise Rotation:\n");
    for(i = 0; i < cols; i++) {
        for(j = 0; j < rows; j++) {
            printf("%4d", rotated[i][j]);
        }
        printf("\n");
    }

    return 0;
}
